<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KAST & Redotpay — Affiliate & Referral Programs Intel | Cashi Strategy</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Satoshi:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --orange:#FF6B2B;--orange-dark:#D94E14;--orange-mid:#FF8A55;
  --orange-light:#FFF0EA;--orange-xlight:#FFF9F6;--orange-border:#FFD4BC;
  --navy:#1A1F36;--navy-mid:#2D3554;--navy-light:#E8ECF8;--navy-xlight:#F4F5FA;
  --bg:#FAFAF8;--white:#FFFFFF;--border:#E8E6E0;--border2:#D8D5CC;
  --t1:#1A1814;--t2:#5C5851;--t3:#9B9790;--t4:#C8C5BE;
  --kast:#5C6EF0;--kast-dk:#3344CC;--kast-lt:#ECEEFF;--kast-bd:#B8C0F8;--kast-mid:#7B8CF5;
  --rdp:#00A388;--rdp-dk:#007A65;--rdp-lt:#E6FAF7;--rdp-bd:#9FE5D5;
  --red:#E8443A;--red-lt:#FEEEEE;
}
html{scroll-behavior:smooth}
body{font-family:'Satoshi',sans-serif;background:var(--bg);color:var(--t1);font-size:15px;line-height:1.65;-webkit-font-smoothing:antialiased;overflow-x:hidden}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(26,31,54,.96);backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,255,255,.07);height:60px;display:flex;align-items:center;padding:0 max(32px,calc(50% - 720px));justify-content:space-between}
.nav-logo{font-family:'Cabinet Grotesk',sans-serif;font-size:18px;font-weight:900;color:white;letter-spacing:-.5px;display:flex;align-items:center;gap:4px;text-decoration:none}
.nav-logo .dot{color:var(--orange);font-size:22px;line-height:0;position:relative;top:3px}
.nav-sub{font-size:11px;color:rgba(255,255,255,.35);margin-left:10px;padding-left:10px;border-left:1px solid rgba(255,255,255,.12)}
.nav-pills{display:flex;gap:4px}
.nav-pill{font-size:11px;font-weight:600;padding:5px 11px;border-radius:6px;color:rgba(255,255,255,.5);text-decoration:none;transition:all .15s;border:1px solid transparent}
.nav-pill:hover{color:rgba(255,255,255,.85);background:rgba(255,255,255,.07)}
.nav-pill.k{color:var(--kast-mid)}
.nav-pill.r{color:var(--rdp)}
.nav-pill.o{color:var(--orange-mid)}

/* ── HERO ── */
.hero{min-height:80vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:100px max(32px,calc(50% - 720px)) 72px;position:relative;overflow:hidden;text-align:center;background:var(--navy)}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 45% at 15% 50%,rgba(92,110,240,.14) 0%,transparent 65%),radial-gradient(ellipse 55% 40% at 85% 50%,rgba(0,163,136,.12) 0%,transparent 65%),radial-gradient(ellipse 40% 30% at 50% -10%,rgba(255,107,43,.1) 0%,transparent 60%);pointer-events:none}
.hero-pill{display:inline-flex;align-items:center;gap:8px;background:rgba(255,107,43,.14);border:1px solid rgba(255,107,43,.28);color:var(--orange-mid);font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:5px 14px;border-radius:20px;margin-bottom:24px;position:relative;z-index:1}
.pill-dot{width:5px;height:5px;border-radius:50%;background:var(--orange);animation:blink 2s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
h1.hero-h{font-family:'Cabinet Grotesk',sans-serif;font-size:clamp(30px,4.2vw,56px);font-weight:900;line-height:1.06;letter-spacing:-2px;color:white;margin-bottom:16px;position:relative;z-index:1}
h1.hero-h em{font-style:normal;color:var(--orange)}
.hero-sub{font-size:15px;color:rgba(255,255,255,.45);max-width:580px;margin:0 auto 48px;line-height:1.8;position:relative;z-index:1}

/* Hero scoreboard */
.hero-scoreboard{display:grid;grid-template-columns:1fr 1px 1fr;position:relative;z-index:1;width:100%;max-width:780px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:20px;overflow:hidden}
.hs-divider{background:rgba(255,255,255,.09)}
.hs-side{padding:28px 36px}
.hs-platform{display:flex;align-items:center;gap:10px;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid rgba(255,255,255,.08)}
.hs-badge{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Cabinet Grotesk',sans-serif;font-size:12px;font-weight:900;color:white;flex-shrink:0}
.hs-badge-k{background:var(--kast)}
.hs-badge-r{background:var(--rdp-dk)}
.hs-platform-name{font-family:'Cabinet Grotesk',sans-serif;font-size:17px;font-weight:900;color:white}
.hs-platform-tag{font-size:10px;color:rgba(255,255,255,.35);margin-top:1px}
.hs-stats{display:grid;grid-template-columns:1fr 1fr;gap:14px 20px}
.hs-stat-val{font-family:'Cabinet Grotesk',sans-serif;font-size:22px;font-weight:900;line-height:1;letter-spacing:-.8px}
.hs-stat-lbl{font-size:10px;color:rgba(255,255,255,.35);margin-top:3px;line-height:1.3}
.kast-c{color:var(--kast-mid)}
.rdp-c{color:var(--rdp)}

/* ── SECTION SHELL ── */
.section{padding:72px max(32px,calc(50% - 720px))}
.section-alt{background:var(--white)}
.section-k{background:var(--kast-lt)}
.section-r{background:var(--rdp-lt)}
.eyebrow{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;margin-bottom:8px}
.eyebrow-k{color:var(--kast)}
.eyebrow-r{color:var(--rdp-dk)}
.eyebrow-o{color:var(--orange)}
.eyebrow-n{color:var(--t4)}
.sh{font-family:'Cabinet Grotesk',sans-serif;font-size:clamp(22px,2.8vw,34px);font-weight:800;line-height:1.1;letter-spacing:-.8px;color:var(--navy);margin-bottom:10px}
.ss{font-size:14px;color:var(--t2);max-width:640px;line-height:1.75;margin-bottom:36px}
hr.div{border:none;border-top:1px solid var(--border);margin:0 max(32px,calc(50% - 720px))}

/* ── PLATFORM HEADER CARD ── */
.platform-header{display:flex;align-items:flex-start;gap:24px;padding:28px 32px;border-radius:18px;border:1.5px solid;margin-bottom:40px}
.ph-k{background:white;border-color:var(--kast-bd)}
.ph-r{background:white;border-color:var(--rdp-bd)}
.ph-badge{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-family:'Cabinet Grotesk',sans-serif;font-size:20px;font-weight:900;color:white;flex-shrink:0}
.ph-badge-k{background:var(--kast)}
.ph-badge-r{background:var(--rdp-dk)}
.ph-right{flex:1}
.ph-name{font-family:'Cabinet Grotesk',sans-serif;font-size:22px;font-weight:900;color:var(--navy);margin-bottom:4px}
.ph-tag{font-size:12px;color:var(--t3);margin-bottom:12px}
.ph-body{font-size:13px;color:var(--t2);line-height:1.7;max-width:680px}
.ph-chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}
.ph-chip{font-size:11px;font-weight:600;padding:4px 11px;border-radius:20px;border:1.5px solid}
.chip-k{background:var(--kast-lt);color:var(--kast-dk);border-color:var(--kast-bd)}
.chip-r{background:var(--rdp-lt);color:var(--rdp-dk);border-color:var(--rdp-bd)}
.chip-orange{background:var(--orange-light);color:var(--orange-dark);border-color:var(--orange-border)}

/* ── TIER TABLE ── */
.tier-wrap{overflow-x:auto;margin-bottom:36px;border-radius:14px;border:1.5px solid var(--border)}
.tier-table{width:100%;border-collapse:collapse;font-size:13px;min-width:700px}
.tier-table thead th{padding:11px 16px;text-align:left;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;background:var(--bg);border-bottom:2px solid var(--border);color:var(--t3)}
.tier-table tbody td{padding:13px 16px;border-bottom:1px solid var(--border);vertical-align:top;line-height:1.5;color:var(--t2);font-size:13px}
.tier-table tbody tr:last-child td{border-bottom:none}
.tier-table tbody tr:hover td{background:rgba(26,31,54,.02)}
.tier-label{font-family:'Cabinet Grotesk',sans-serif;font-weight:900;font-size:14px}
.tier-label-k{color:var(--kast-dk)}
.tier-label-r{color:var(--rdp-dk)}
.tier-threshold{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:5px;margin-top:3px}
.tt-k{background:var(--kast-lt);color:var(--kast-dk)}
.tt-r{background:var(--rdp-lt);color:var(--rdp-dk)}
.tier-highlight{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;color:var(--navy);font-size:15px}
.tier-sub{font-size:11px;color:var(--t3);display:block;margin-top:2px}
.invite-tag{display:inline-block;font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px;background:var(--orange-light);color:var(--orange-dark);border:1px solid var(--orange-border);margin-left:6px;vertical-align:middle}
.hidden-tag{display:inline-block;font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px;background:#FEF4E0;color:#8C5E00;border:1px solid #F5C870;margin-left:6px;vertical-align:middle}

/* ── COMMISSION STREAM CARDS ── */
.stream-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:36px}
.stream-card{border-radius:14px;border:1.5px solid var(--border);background:var(--white);padding:20px 22px}
.stream-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;margin-bottom:14px}
.si-k{background:var(--kast-lt)}
.si-r{background:var(--rdp-lt)}
.si-o{background:var(--orange-light)}
.stream-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px}
.sl-k{color:var(--kast)}
.sl-r{color:var(--rdp-dk)}
.sl-o{color:var(--orange-dark)}
.stream-rate{font-family:'Cabinet Grotesk',sans-serif;font-size:26px;font-weight:900;line-height:1;letter-spacing:-.8px;color:var(--navy);margin-bottom:6px}
.stream-title{font-size:13px;font-weight:700;color:var(--t1);margin-bottom:6px;line-height:1.3}
.stream-body{font-size:12px;color:var(--t2);line-height:1.6}
.stream-timing{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:700;padding:3px 9px;border-radius:6px;margin-top:10px}
.st-instant{background:#E8F5E9;color:#2E7D32;border:1px solid #A5D6A7}
.st-30d{background:var(--red-lt);color:var(--red);border:1px solid #FFCDD2}
.st-weekly{background:var(--orange-light);color:var(--orange-dark);border:1px solid var(--orange-border)}
.st-tge{background:var(--kast-lt);color:var(--kast-dk);border:1px solid var(--kast-bd)}

/* ── PROMO / LEADERBOARD ── */
.promo-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:36px}
.promo-card{border-radius:16px;padding:26px 28px;border:1.5px solid}
.promo-2x{background:var(--navy);border-color:var(--navy-mid)}
.promo-lb{background:var(--kast-lt);border-color:var(--kast-bd)}
.promo-label{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:10px}
.pl-white{color:rgba(255,255,255,.4)}
.pl-k{color:var(--kast)}
.promo-title{font-family:'Cabinet Grotesk',sans-serif;font-size:20px;font-weight:900;line-height:1.1;margin-bottom:10px;letter-spacing:-.4px}
.pt-white{color:white}
.pt-navy{color:var(--navy)}
.promo-body{font-size:13px;line-height:1.65}
.pb-white{color:rgba(255,255,255,.5)}
.pb-dark{color:var(--t2)}
.promo-highlight{font-family:'Cabinet Grotesk',sans-serif;font-size:13px;font-weight:800;color:var(--orange)}
.lb-prizes{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:16px}
.lb-prize{text-align:center;padding:14px 10px;border-radius:10px;background:white;border:1.5px solid var(--kast-bd)}
.lb-rank{font-size:10px;font-weight:700;color:var(--t4);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px}
.lb-amount{font-family:'Cabinet Grotesk',sans-serif;font-size:22px;font-weight:900;color:var(--kast-dk);letter-spacing:-.5px}
.lb-cur{font-size:10px;color:var(--kast);font-weight:600;margin-top:2px}
.lb-1st .lb-rank{color:var(--orange-dark)}
.lb-1st .lb-amount{color:var(--orange-dark)}
.lb-1st{border-color:var(--orange-border);background:var(--orange-xlight)}

/* ── FOUR PROGRAMS ── */
.four-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:36px}
.four-card{border-radius:14px;border:1.5px solid var(--rdp-bd);background:white;padding:18px 16px;position:relative}
.four-card.four-invite::after{content:'Invite Only';position:absolute;top:12px;right:12px;font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px;background:var(--orange-light);color:var(--orange-dark);border:1px solid var(--orange-border)}
.four-num{font-family:'Cabinet Grotesk',sans-serif;font-size:11px;font-weight:900;color:var(--rdp-dk);letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px}
.four-title{font-family:'Cabinet Grotesk',sans-serif;font-size:15px;font-weight:800;color:var(--navy);margin-bottom:8px;line-height:1.2}
.four-body{font-size:12px;color:var(--t2);line-height:1.6}
.four-tag{display:inline-block;font-size:10px;font-weight:700;padding:3px 8px;border-radius:5px;background:var(--rdp-lt);color:var(--rdp-dk);border:1px solid var(--rdp-bd);margin-top:10px}

/* ── META CARDS (payout/access) ── */
.meta-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:36px}
.meta-card{border-radius:14px;border:1.5px solid var(--border);background:var(--white);padding:20px 22px}
.meta-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--t4);margin-bottom:10px}
.meta-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px}
.meta-row:last-child{border-bottom:none;padding-bottom:0}
.meta-key{color:var(--t3);font-size:12px}
.meta-val{font-weight:700;color:var(--t1);font-size:12px;text-align:right;max-width:60%}

/* ── WEAKNESS CARDS ── */
.weak-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:36px}
.weak-col{}
.weak-col-header{display:flex;align-items:center;gap:10px;padding:14px 18px;border-radius:12px;margin-bottom:14px}
.wch-k{background:var(--kast-lt);border:1.5px solid var(--kast-bd)}
.wch-r{background:var(--rdp-lt);border:1.5px solid var(--rdp-bd)}
.wch-badge{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-family:'Cabinet Grotesk',sans-serif;font-size:11px;font-weight:900;color:white;flex-shrink:0}
.wbg-k{background:var(--kast)}
.wbg-r{background:var(--rdp-dk)}
.wch-name{font-family:'Cabinet Grotesk',sans-serif;font-size:15px;font-weight:900;color:var(--navy)}
.weak-card{border-radius:12px;border:1.5px solid var(--border);background:var(--white);padding:16px 18px;margin-bottom:10px;transition:all .2s;position:relative;overflow:hidden}
.weak-card-k::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--kast)}
.weak-card-r::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--rdp)}
.weak-card-crit::before{background:var(--red)}
.weak-sev{font-size:9px;font-weight:800;padding:2px 7px;border-radius:4px;display:inline-block;margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em}
.sev-high{background:var(--red-lt);color:var(--red);border:1px solid #FFCDD2}
.sev-med{background:#FEF4E0;color:#8C5E00;border:1px solid #F5C870}
.weak-title{font-weight:700;color:var(--t1);font-size:13px;margin-bottom:5px}
.weak-body{font-size:12px;color:var(--t2);line-height:1.6}

/* ── COMPARISON TABLE ── */
.comp-wrap{overflow-x:auto;border-radius:14px;border:1.5px solid var(--border)}
.comp-table{width:100%;border-collapse:collapse;font-size:13px;min-width:680px}
.comp-table thead tr th{padding:11px 16px;text-align:left;font-weight:700;font-size:10px;letter-spacing:.08em;text-transform:uppercase;border-bottom:2px solid}
.th-dim{color:var(--t3);border-color:var(--border);background:var(--bg);width:28%}
.th-kast{color:var(--kast-dk);border-color:var(--kast);background:var(--kast-lt);width:36%}
.th-rdp{color:var(--rdp-dk);border-color:var(--rdp);background:var(--rdp-lt);width:36%}
.comp-table tbody td{padding:11px 16px;border-bottom:1px solid var(--border);vertical-align:top;line-height:1.55;color:var(--t2);font-size:13px}
.comp-table td:first-child{font-weight:700;color:var(--t1);font-size:12px;background:var(--bg)}
.comp-table tr:last-child td{border-bottom:none}
.comp-table tbody tr:hover td{filter:brightness(.98)}
.badge-k{display:inline-block;font-size:9px;font-weight:800;padding:2px 6px;border-radius:4px;background:var(--kast-lt);color:var(--kast-dk);border:1px solid var(--kast-bd);margin-left:4px;vertical-align:middle;white-space:nowrap}
.badge-r{display:inline-block;font-size:9px;font-weight:800;padding:2px 6px;border-radius:4px;background:var(--rdp-lt);color:var(--rdp-dk);border:1px solid var(--rdp-bd);margin-left:4px;vertical-align:middle;white-space:nowrap}
.badge-tie{display:inline-block;font-size:9px;font-weight:800;padding:2px 6px;border-radius:4px;background:var(--bg);color:var(--t3);border:1px solid var(--border);margin-left:4px;vertical-align:middle}
.badge-warn{display:inline-block;font-size:9px;font-weight:800;padding:2px 6px;border-radius:4px;background:var(--red-lt);color:var(--red);border:1px solid #FFCDD2;margin-left:4px;vertical-align:middle}
.cell-k{background:rgba(92,110,240,.03)}
.cell-r{background:rgba(0,163,136,.03)}
.strong{font-weight:700;color:var(--t1)}

/* ── POSITIONING VERDICT ── */
.verdict-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:36px}
.verdict-card{border-radius:16px;padding:22px 24px;border:1.5px solid}
.vc-k{background:var(--kast-lt);border-color:var(--kast-bd)}
.vc-r{background:var(--rdp-lt);border-color:var(--rdp-bd)}
.vc-cashi{background:var(--orange-xlight);border-color:var(--orange-border)}
.verdict-label{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:8px}
.vl-k{color:var(--kast)}
.vl-r{color:var(--rdp-dk)}
.vl-o{color:var(--orange-dark)}
.verdict-title{font-family:'Cabinet Grotesk',sans-serif;font-size:17px;font-weight:900;color:var(--navy);margin-bottom:10px;line-height:1.2}
.verdict-body{font-size:12px;color:var(--t2);line-height:1.65}
.verdict-quote{font-style:italic;font-size:13px;color:var(--t1);margin-top:12px;padding-top:10px;border-top:1px solid var(--orange-border);line-height:1.6}

/* ── SOURCES ── */
.sources-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.source-row{display:flex;align-items:flex-start;gap:10px;font-size:12px;color:var(--t2);padding:8px 12px;background:var(--white);border-radius:8px;border:1px solid var(--border)}
.source-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:5px}
.sd-k{background:var(--kast)}
.sd-r{background:var(--rdp)}
.sd-o{background:var(--orange)}
.source-row a{color:var(--t2);text-decoration:none;transition:color .15s}
.source-row a:hover{color:var(--navy)}

/* ── FOOTER ── */
footer{background:var(--navy);border-top:1px solid rgba(255,255,255,.07);padding:24px max(32px,calc(50% - 720px));display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.foot-logo{font-family:'Cabinet Grotesk',sans-serif;font-size:16px;font-weight:900;color:rgba(255,255,255,.7)}
.foot-logo .dot{color:var(--orange)}
.foot-note{font-size:11px;color:rgba(255,255,255,.25)}

/* ── PRINT ── */
@media print{
  nav,footer{display:none}
  body{font-size:12px}
  .hero{min-height:auto;padding:40px 32px 32px}
  .section{padding:36px 32px}
  h1.hero-h{font-size:32px}
  .promo-2x{background:#1A1F36 !important;-webkit-print-color-adjust:exact;print-color-adjust:exact}
  .hero{-webkit-print-color-adjust:exact;print-color-adjust:exact}
  .section-k,.section-r{-webkit-print-color-adjust:exact;print-color-adjust:exact}
  .stream-card,.weak-card,.four-card,.meta-card,.verdict-card{break-inside:avoid}
  .tier-wrap{break-inside:avoid}
}

/* ── RESPONSIVE ── */
@media(max-width:960px){
  nav{padding:0 20px}
  .nav-pills{display:none}
  .hero{padding:90px 20px 52px;min-height:auto}
  h1.hero-h{letter-spacing:-1px}
  .hero-scoreboard{grid-template-columns:1fr}
  .hs-divider{display:none}
  .section{padding:52px 20px}
  .stream-grid{grid-template-columns:1fr 1fr}
  .four-grid{grid-template-columns:1fr 1fr}
  .promo-grid,.weak-grid,.verdict-grid,.meta-grid{grid-template-columns:1fr}
  .comp-table thead th,.comp-table tbody td{padding:9px 10px}
}
@media(max-width:600px){
  .stream-grid,.four-grid,.sources-grid{grid-template-columns:1fr}
  .platform-header{flex-direction:column}
}
</style>
</head>
